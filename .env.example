# NEVER commit .env to Git. Production: set DINETRADE_SECRETS_BACKEND=aws|gcp|docker
# and use AWS Secrets Manager, GCP Secret Manager, or Docker secrets; keys fall back to env.

########################################
## LLM / GEMINI
########################################

# Gemini (model hybridization: Pro for Researcher, Flash for Sentiment/Chartist)
GEMINI_API_KEY=
GEMINI_MODEL_RESEARCHER=gemini-3.1-pro-preview
GEMINI_MODEL_FAST=gemini-3-flash-preview

########################################
## BROKERS / EXECUTION
########################################

# Alpaca (equities). For paper trading use paper base URL below.
# Key = APCA_API_KEY_ID, Secret = APCA_API_SECRET_KEY. No quotes in .env.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# OANDA (forex / CFD). Use practice for demo, live for production.
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice  # practice | live

# Binance (crypto) — market data only unless you wire trading.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

########################################
## DATA PROVIDERS
########################################

# FMP (Financial Modeling Prep) — news + fundamentals
FMP_API_KEY=

# Polygon.io — secondary data & WebSocket ticks
POLYGON_API_KEY=

########################################
## SUPABASE (DATABASE + AUTH)
########################################

# Backend (Python) — service role key used for trade_log, daily_state, agent_runs, post_mortem, etc.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Frontend (JS) — anon key for Supabase Auth + RLS-protected tables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

########################################
## VECTOR DB (PINECONE)
########################################

PINECONE_API_KEY=
PINECONE_INDEX_NAME=

########################################
## REDIS / STATE CACHE
########################################

# Used by streamers, feature engineering, WebSockets, and /ws/state.
REDIS_URL=redis://localhost:6379/0

########################################
## RISK LIMITS / MODE
########################################

# Daily drawdown limit (equities/forex). Crypto uses 3% by default in code.
DAILY_DRAWDOWN_LIMIT_PCT=1.5
MAX_RISK_PER_TRADE_PCT=1.0

# Paper vs live; live requires explicit confirmation in UI.
PAPER_MODE=true

# Global kill switch. If false, run_live exits before trading.
TRADING_ENABLED=true

########################################
## FRONTEND API / WS ENDPOINTS
########################################

# Base URL for TradeClaw API (FastAPI). For local dev leave default.
VITE_API_BASE_URL=http://localhost:8000

# Override WebSocket base if deploying API separately; otherwise derived from window.location.
VITE_WS_BASE_URL=

########################################
## NOTIFICATIONS / TELEGRAM (OPTIONAL)
########################################

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# NEVER commit .env to Git. Production: set DINETRADE_SECRETS_BACKEND=aws|gcp|docker
# and use AWS Secrets Manager, GCP Secret Manager, or Docker secrets; keys fall back to env.

# Gemini (model hybridization: Pro for Researcher, Flash for Sentiment/Chartist)
GEMINI_API_KEY=
GEMINI_MODEL_RESEARCHER=gemini-3.1-pro-preview
GEMINI_MODEL_FAST=gemini-3-flash-preview

# Alpaca (paper): use Key = APCA_API_KEY_ID, Secret = APCA_API_SECRET_KEY. No quotes in .env.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets
PAPER_MODE=true

# Data (Alpaca = OHLCV + quote; Polygon optional; FMP = news)
FMP_API_KEY=
POLYGON_API_KEY=

# Supabase (trade_log, daily_state, agent_runs, post_mortem)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Risk
DAILY_DRAWDOWN_LIMIT_PCT=1.5
MAX_RISK_PER_TRADE_PCT=1.0

# Kill-switch
TRADING_ENABLED=true
